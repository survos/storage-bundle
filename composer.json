{
    "name": "survos/storage-bundle",
    "description": "Symfony bundle for interacting with storage (via Flysystem)",
    "keywords": [
        "symfony-ux",
        "symfony"
    ],
    "license": "MIT",
    "type": "symfony-bundle",
    "require": {
        "php": "^8.5",
        "symfony/config": "^8.1",
        "symfony/dependency-injection": "^8.1",
        "symfony/http-kernel": "^8.1",
        "twig/twig": "^3.4",
        "league/flysystem-bundle": "^3.5",
        "zenstruck/bytes": "^1.0",
        "ext-zip": "*",
        "doctrine/orm": "^3.6",
        "doctrine/doctrine-bundle": "^3.2",
        "survos/jsonl-bundle": "^2.5",
        "symfony/string": "^8.1",
        "survos/kit-bundle": "^2.5"
    },
    "require-dev": {
        "league/flysystem-aws-s3-v3": "^3.29",
        "phpstan/phpstan": "^2.0",
        "symfony/browser-kit": "^8.1",
        "symfony/framework-bundle": "^8.1",
        "symfony/phpunit-bridge": "^8.1",
        "symfony/twig-bundle": "^8.1",
        "symfony/var-dumper": "^8.1",
        "survos/simple-datatables-bundle": "^2.5",
        "symfony/yaml": "^8.1",
        "symfony/http-client": "^8.1",
        "phpunit/phpunit": "^13.0",
        "symfony/messenger": "^8.1",
        "symfony/console": "^8.1",
        "phpstan/phpstan-symfony": "^2.0",
        "symfony/stopwatch": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Survos\\StorageBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Survos\\StorageBundle\\Tests\\": "Tests/"
        }
    },
    "suggest": {
        "mezcalito/imgproxy-bundle": "optional thumbnail and preview rendering for image objects",
        "survos/simple-datatables-bundle": "searchable/sortable tables when browsing"
    }
}